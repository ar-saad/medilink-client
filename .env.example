# =========================================================================
# 🩺 MediLink Client Environment Variables Configuration Template
# =========================================================================
# Copy this file to `.env` in the same directory and fill out the values.
# DO NOT commit actual secrets or production keys to version control!
# =========================================================================

# 📡 Backend API Configuration
# Base endpoint for backend API requests (including api version suffix)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1

# 🔑 JWT Configuration Secrets
# Must match the JWT_ACCESS_TOKEN_SECRET configured on the backend server for decryption and verification
JWT_ACCESS_TOKEN_SECRET=your_super_secret_access_token_decryption_key_must_match_backend_key
